// ─────────────────────────────────────────────────────────────────────────────
// RustPipe — Nextflow configuration
//
// Edit the params block below to change inputs and resource limits.
// Switch container engines with: -profile docker  or  -profile singularity
// ─────────────────────────────────────────────────────────────────────────────

// ── Pipeline parameters ───────────────────────────────────────────────────────
// Override any of these on the command line with --param_name value.
params {
    // Required inputs (no defaults — must be supplied at runtime)
    input      = null   // Path to merged count matrix TSV (genes × samples)
    metadata   = null   // Path to samplesheet CSV
    group_col  = null   // Column name in samplesheet that defines contrast groups

    // Optional gene-set file for GSEA (GMT or JSON).
    // Leave as null to skip enrichment.
    gene_sets  = null

    // Where to write results
    outdir     = 'results'

    // Extra arguments passed directly to `rustpipe pipeline`.
    // Example: '--min-count 5 --fdr 0.05'
    extra_args = ''
}

// ── Process resource defaults ─────────────────────────────────────────────────
// process_medium is the label used by the RUSTPIPE module.
// Adjust these to match your compute environment.
process {
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
    }

    // Publish all RUSTPIPE outputs to params.outdir, preserving sub-directories.
    withName: 'RUSTPIPE' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy',
            saveAs: { filename -> filename }
        ]
        ext.args = params.extra_args
    }
}

// ── Container engine profiles ─────────────────────────────────────────────────
// Run with: nextflow run ... -profile docker
//       or: nextflow run ... -profile singularity
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }

    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }

    // Quick local test — reduces resource requests so the pipeline runs on a laptop.
    test {
        params.input     = 'tests/data/counts_test.tsv'
        params.metadata  = 'tests/data/samplesheet_test.csv'
        params.group_col = 'condition'

        process {
            withLabel: 'process_medium' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
        }
    }
}

// ── Nextflow execution settings ───────────────────────────────────────────────
// Keep run caches so -resume works correctly.
resume = true

manifest {
    name            = 'jwg054000/RustPipe'
    author          = 'Josh Garton'
    homePage        = 'https://github.com/jwg054000/RustPipe'
    description     = 'Fast downstream RNA-seq analysis in Rust'
    mainScript      = 'workflows/rustpipe.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}
